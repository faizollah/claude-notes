{
  "manifest_version": 3,
  "name": "Claude Notes",
  "version": "1.0.0",
  "description": "Capture, organize, and revisit valuable AI text responses from Claude.ai",
  "permissions": ["storage", "activeTab", "scripting", "notifications", "identity"],
  "host_permissions": ["https://claude.ai/*", "https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "238716688165-cc2v79nuh4n6mgc6q6aq4p6b8d815qsh.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.appdata"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["icons.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["library.html", "library.js", "library.css"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
} 